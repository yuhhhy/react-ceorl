{
  "name": "ceorl",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/ceorl.cjs",
  "module": "./dist/ceorl.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ceorl.mjs",
      "require": "./dist/ceorl.cjs",
      "types": "./dist/src/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsgo -config tsconfig.app.json && vite build",
    "typecheck": "tsgo -config tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@rslint/tsgo": "^0.5.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.7"
  }
}
